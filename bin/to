#!/usr/bin/env zsh

set -u

typeset -g _TO_CLI_SCRIPT_PATH="${0:A}"

_to_cli_usage() {
  cat <<'EOF'
Usage:
  to init zsh       Print zsh integration script
  to --doctor       Check dependencies and config
  to --reindex      Rebuild the directory index
  to --version      Show version
  to --help         Show this help

After initialization, the zsh function named `to` handles directory jumps:

  eval "$(to init zsh)"
  to use ~/Projects
  to backend
EOF
}

_to_cli_plugin_path() {
  local script_dir prefix

  script_dir="${_TO_CLI_SCRIPT_PATH:h}"
  prefix="${script_dir:h}"

  if [[ -r "$prefix/share/to/to.plugin.zsh" ]]; then
    print -r -- "$prefix/share/to/to.plugin.zsh"
    return 0
  fi

  if [[ -r "${_TO_CLI_SCRIPT_PATH:h:h}/to.plugin.zsh" ]]; then
    print -r -- "${_TO_CLI_SCRIPT_PATH:h:h}/to.plugin.zsh"
    return 0
  fi

  if [[ -r "./to.plugin.zsh" ]]; then
    print -r -- "${PWD:A}/to.plugin.zsh"
    return 0
  fi

  return 1
}

_to_cli_run_plugin_command() {
  local plugin_path

  plugin_path="$(_to_cli_plugin_path)" || {
    print -u2 -- "to: could not locate to.plugin.zsh"
    exit 1
  }
  source "$plugin_path"
  to "$@"
}

case "${1:-}" in
  init)
    case "${2:-}" in
      zsh|"")
        plugin_path="$(_to_cli_plugin_path)" || {
          print -u2 -- "to: could not locate to.plugin.zsh"
          exit 1
        }
        printf 'source %q\n' "$plugin_path"
        ;;
      *)
        print -u2 -- "to: unsupported shell: $2"
        print -u2 -- "to: currently supported: zsh"
        exit 2
        ;;
    esac
    ;;
  --doctor|--reindex|--watch|use|unuse|roots|add|alias|remove|unalias|aliases|workspace|unwork|workspaces)
    _to_cli_run_plugin_command "$@"
    ;;
  --version|-V)
    _to_cli_run_plugin_command "$@"
    ;;
  --help|-h|help|"")
    _to_cli_usage
    ;;
  *)
    print -u2 -- "to: shell integration is not loaded"
    print -u2 -- 'to: add this to ~/.zshrc: eval "$(to init zsh)"'
    exit 2
    ;;
esac
